@model Thue_san_the_thao.Models.Data.User


@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="~/Images/logo.jpg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Thuê Sân Thể Thao</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <style>
        :root {
            --green: #00CC33;
            --green-dark: #009926;
            --green-pale: #e6fff0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f4f6f4;
        }

        /* ===== Wrapper 2 cột ===== */
        .login-wrapper {
            display: flex;
            width: 900px;
            max-width: 96vw;
            min-height: 520px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 12px 40px rgba(0,0,0,0.14);
        }

        /* ===== Cột trái: banner ===== */
        .login-banner {
            flex: 1;
            background: var(--green);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 36px;
            color: #fff;
            text-align: center;
        }

            .login-banner .icon {
                font-size: 4rem;
                margin-bottom: 20px;
            }

            .login-banner h1 {
                font-size: 1.6rem;
                font-weight: 700;
                margin-bottom: 12px;
            }

            .login-banner p {
                font-size: 0.9rem;
                opacity: 0.85;
                line-height: 1.7;
            }

        .banner-features {
            list-style: none;
            margin-top: 28px;
            text-align: left;
            width: 100%;
        }

            .banner-features li {
                display: flex;
                align-items: center;
                gap: 10px;
                font-size: 0.875rem;
                margin-bottom: 12px;
                opacity: 0.9;
            }

                .banner-features li i {
                    background: rgba(255,255,255,0.2);
                    width: 28px;
                    height: 28px;
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 0.75rem;
                    flex-shrink: 0;
                }

        /* ===== Cột phải: form ===== */
        .login-form-box {
            flex: 1;
            background: #fff;
            padding: 48px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 6px;
        }

        .form-subtitle {
            font-size: 0.875rem;
            color: #888;
            margin-bottom: 32px;
        }

        /* Input group */
        .field {
            margin-bottom: 20px;
        }

            .field label {
                display: block;
                font-size: 0.85rem;
                font-weight: 600;
                color: #333;
                margin-bottom: 6px;
            }

        .input-wrap {
            position: relative;
        }

            .input-wrap i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #aaa;
                font-size: 0.85rem;
                pointer-events: none;
            }

            .input-wrap input {
                width: 100%;
                padding: 11px 14px 11px 38px;
                border: 1.5px solid #ddd;
                border-radius: 10px;
                font-size: 0.9rem;
                color: #1a1a1a;
                outline: none;
                transition: border-color 0.2s, box-shadow 0.2s;
                background: #fafafa;
            }

                .input-wrap input:focus {
                    border-color: var(--green);
                    box-shadow: 0 0 0 3px rgba(0,204,51,0.12);
                    background: #fff;
                }

            /* Toggle mật khẩu */
            .input-wrap .toggle-pw {
                position: absolute;
                left: 350px;
                top: 50%;
                transform: translateY(-50%);
                color: #aaa;
                cursor: pointer;
                font-size: 0.85rem;
                pointer-events: all;
            }

                .input-wrap .toggle-pw:hover {
                    color: var(--green);
                }

        /* Lỗi validation */
        .field-error {
            font-size: 0.78rem;
            color: #e53935;
            margin-top: 5px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* Ghi nhớ + Quên mật khẩu */
        .form-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
            font-size: 0.85rem;
        }

            .form-options label {
                display: flex;
                align-items: center;
                gap: 7px;
                color: #555;
                cursor: pointer;
            }

            .form-options input[type="checkbox"] {
                accent-color: var(--green);
                width: 15px;
                height: 15px;
            }

            .form-options a {
                color: var(--green-dark);
                text-decoration: none;
                font-weight: 500;
            }

                .form-options a:hover {
                    text-decoration: underline;
                }

        /* Nút đăng nhập */
        .btn-submit {
            width: 100%;
            padding: 12px;
            background: var(--green);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-submit:hover {
                background: var(--green-dark);
                transform: translateY(-1px);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

        /* Đăng ký */
        .form-footer {
            text-align: center;
            margin-top: 24px;
            font-size: 0.875rem;
            color: #888;
        }

            .form-footer a {
                color: var(--green-dark);
                font-weight: 600;
                text-decoration: none;
            }

                .form-footer a:hover {
                    text-decoration: underline;
                }

        /* Alert lỗi từ server */
        .alert-error {
            background: #fff5f5;
            border: 1px solid #ffcdd2;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.875rem;
            color: #c62828;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }

        /* ===== Responsive: ẩn banner trên mobile ===== */
        @@media (max-width: 640px) {
            .login-banner {
                display: none;
            }

            .login-form-box {
                padding: 36px 24px;
            }

            .login-wrapper {
                border-radius: 16px;
            }
        }
    </style>
</head>
<body>

    <div class="login-wrapper">

        <!-- ===== Cột trái: Banner ===== -->
        <div class="login-banner">
            <img src="~/Images/logo.jpg" alt="H2D Sport" style="width:60px; height:60px; border-radius:50%; object-fit:cover;" />
            <h1>Thuê Sân Thể Thao</h1>
            <p>Đặt sân nhanh chóng, tiện lợi<br>mọi lúc mọi nơi</p>

            <ul class="banner-features">
                <li>
                    <i class="fas fa-calendar-check"></i>
                    Đặt sân online 24/7
                </li>
                <li>
                    <i class="fas fa-bolt"></i>
                    Xác nhận tức thì
                </li>
                <li>
                    <i class="fas fa-shield-halved"></i>
                    Thanh toán an toàn
                </li>
                <li>
                    <i class="fas fa-store"></i>
                    Mua đồ thể thao tiện lợi
                </li>
            </ul>
        </div>

        <!-- ===== Cột phải: Form đăng nhập ===== -->
        <div class="login-form-box">

            <h2 class="form-title">Chào mừng trở lại!</h2>
            <p class="form-subtitle">Đăng nhập để tiếp tục sử dụng dịch vụ</p>

            @* Hiển thị lỗi từ server nếu có *@
            @if (ViewBag.Error != null)
            {
                <div class="alert-error">
                    <i class="fas fa-circle-exclamation"></i>
                    @ViewBag.Error
                </div>
            }

            @using (Html.BeginForm("Login", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @* Email *@
                <div class="field">
                    <label for="email">Email</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email"
                               id="email"
                               name="Email"
                               value="@Model.Email"
                               placeholder="example@email.com"
                               required
                               autocomplete="email" />
                    </div>
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
                </div>

                @* Mật khẩu *@
                <div class="field">
                    <label for="password">Mật khẩu</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock"></i>
                        <input type="password"
                               id="password"
                               name="Password"
                               placeholder="Nhập mật khẩu"
                               required
                               autocomplete="current-password" />
                        <i class="fas fa-eye toggle-pw" id="togglePw" title="Hiện mật khẩu"></i>
                    </div>
                    @Html.ValidationMessageFor(m => m.PasswordHash, "", new { @class = "field-error" })
                </div>

                @* Ghi nhớ + Quên mật khẩu *@
                <div class="form-options">
                    <label>
                        <input type="checkbox" name="RememberMe" value="true" />
                        Ghi nhớ đăng nhập
                    </label>
                    <a href="/Account/ForgotPassword">Quên mật khẩu?</a>
                </div>

                @* Nút đăng nhập *@
                <button type="submit" class="btn-submit">
                    <i class="fas fa-right-to-bracket"></i>
                    Đăng nhập
                </button>
            }

            @* Link đăng ký *@
            <div class="form-footer">
                Chưa có tài khoản?
                <a href="/Account/Register">Đăng ký ngay</a>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>// Toggle hiện / ẩn mật khẩu
        const toggleBtn = document.getElementById('togglePw');
        const pwInput = document.getElementById('password');

        toggleBtn.addEventListener('click', () => {
            const isHidden = pwInput.type === 'password';
            pwInput.type = isHidden ? 'text' : 'password';
            toggleBtn.className = isHidden
                ? 'fas fa-eye-slash toggle-pw'
                : 'fas fa-eye toggle-pw';
        });</script>

</body>
</html>

