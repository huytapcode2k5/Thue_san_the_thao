
@{
    ViewBag.Title = "Chỉnh sửa sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_layoutAdmin.cshtml";
}

@model Thue_san_the_thao.Models.Data.Product


<style>
    /* ===== GLOBAL ===== */
    body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #eef2ff, #f8fafc);
    }

    /* ===== HEADER ===== */
    .page-header {
        display: flex;
        justify-content: end;
        align-items: center;
        margin-bottom: 25px;
    }

    .page-title {
        font-size: 26px;
        font-weight: 700;
        color: #1e293b;
    }

    /* ===== BUTTON ===== */
    .btn {
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        transition: 0.25s;
    }

    .btn-primary {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        box-shadow: 0 6px 20px rgba(99,102,241,0.35);
    }

        .btn-primary:hover {
            transform: translateY(-2px);
        }

    .btn-outline {
        border: 1px solid #4e73df;
        color: #4e73df;
        background: transparent;
    }

        .btn-outline:hover {
            background-color: #4e73df;
            color: white;
        }

    .btn-ghost {
        background: transparent;
        color: #64748b;
    }

    /* ===== CARD ===== */
    .form-card-wide {
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px);
        padding: 30px;
        border-radius: 18px;
        box-shadow: 0 12px 35px rgba(0,0,0,0.08);
    }

    /* ===== SECTION ===== */
    .form-section-title {
        font-size: 15px;
        font-weight: 600;
        color: #6366f1;
        margin-bottom: 15px;
        border-left: 4px solid #6366f1;
        padding-left: 10px;
    }

    /* ===== FORM GRID ===== */
    .form-row {
        display: flex;
        gap: 20px;
        margin-bottom: 18px;
    }

    .form-group {
        flex: 1;
    }

    /* ===== INPUT ===== */
    .form-label {
        display: block;
        margin-bottom: 6px;
        font-weight: 600;
        color: #334155;
    }

    .form-control {
        width: 100%;
        padding: 12px 14px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        transition: 0.25s;
    }

        .form-control:focus {
            border-color: #6366f1;
            background: white;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
            outline: none;
        }

    /* ===== VALIDATION ===== */
    .validation-msg {
        color: #ef4444;
        font-size: 13px;
        margin-top: 4px;
    }

    /* ===== IMAGE UPLOAD ===== */
    .image-upload-area {
        border: 2px dashed #c7d2fe;
        border-radius: 14px;
        padding: 20px;
        background: #f8fafc;
        text-align: center;
    }

    /* preview wrap */
    .image-preview-wrap {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    /* image */
    .image-preview {
        width: 110px;
        height: 110px;
        border-radius: 12px;
        object-fit: cover;
        border: 1px solid #e5e7eb;
    }

    /* placeholder */
    .image-placeholder {
        width: 110px;
        height: 110px;
        border-radius: 12px;
        background: #eef2ff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #6366f1;
        font-size: 13px;
    }

    /* info */
    .image-info {
        text-align: left;
    }

    .image-filename {
        font-weight: 600;
        color: #1e293b;
    }

    .image-hint {
        font-size: 12px;
        color: #94a3b8;
    }

    /* hidden input */
    .file-input {
        display: none;
    }

    /* upload button */
    .btn-upload {
        display: inline-block;
        margin-top: 12px;
        padding: 8px 14px;
        background: #6366f1;
        color: white;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-upload:hover {
            background: #4f46e5;
        }

    /* ===== ACTION ===== */
    .form-actions {
        margin-top: 25px;
        display: flex;
        gap: 12px;
    }

    /* ===== ANIMATION ===== */
    .form-card-wide {
        animation: fadeUp 0.4s ease;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .form-row {
            flex-direction: column;
        }

        .image-preview-wrap {
            flex-direction: column;
            text-align: center;
        }
    }
</style>


<div class="page-header">
    <a href="@Url.Action("Index", "Product")" class="btn btn-outline">← Quay lại</a>
</div>

@using (Html.BeginForm("Edit", "Product", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ProductID)
    @Html.HiddenFor(m => m.ProductDate)
    @Html.HiddenFor(m => m.Image)

<div class="form-card-wide">

    <div class="form-section-title">Thông tin cơ bản</div>

    <div class="form-row">
        <div class="form-group">
            @Html.LabelFor(m => m.Name, "Tên sản phẩm", new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Nhập tên ..." })
            @Html.ValidationMessageFor(m => m.Name, "", new { @class = "validation-msg" })
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            @Html.LabelFor(m => m.Price, "Giá (VNĐ)", new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", min = "0" })
            @Html.ValidationMessageFor(m => m.Price, "", new { @class = "validation-msg" })
        </div>

        <!-- 🆕 STOCK -->
        <div class="form-group">
            @Html.LabelFor(m => m.Stock, "Tồn kho", new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Stock, new { @class = "form-control", type = "number", min = "0" })
            @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "validation-msg" })
        </div>
    </div>

    <!-- 🆕 DESCRIPTION -->
    <div class="form-row">
        <div class="form-group">
            @Html.LabelFor(m => m.Description, "Mô tả", new { @class = "form-label" })
            @Html.TextAreaFor(m => m.Description, new
            {
                @class = "form-control",
                rows = "3",
                placeholder = "Nhập mô tả sản phẩm..."
            })
            @Html.ValidationMessageFor(m => m.Description, "", new { @class = "validation-msg" })
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            @Html.LabelFor(m => m.CategoryID, "Danh mục", new { @class = "form-label" })
            @Html.DropDownList("CategoryId", ViewBag.CategoryId as SelectList, "-- Chọn danh mục --", new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.CategoryID, "", new { @class = "validation-msg" })
        </div>
    </div>

    <div class="form-section-title">Hình ảnh</div>

    <div class="image-upload-area">
        <div class="image-preview-wrap">
            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <img id="imgPreview" src="~/Images/@Model.Image" class="image-preview" alt="@Model.Name" />
                <div id="imgPlaceholder" class="image-placeholder" style="display:none">
                    <span>Chưa có ảnh</span>
                </div>
            }
            else
            {
                <div id="imgPlaceholder" class="image-placeholder">
                    <span>Chưa có ảnh</span>
                </div>
                <img id="imgPreview" src="" style="display:none" class="image-preview" />
            }

            <div class="image-info">
                <div class="image-filename" id="imgName">
                    @(string.IsNullOrEmpty(Model.Image) ? "Chưa có ảnh" : Model.Image)
                </div>
                <div class="image-hint">Để trống nếu không muốn đổi ảnh</div>
            </div>
        </div>

        <input type="file" name="upload" id="upload" class="file-input" onchange="previewImage(this)" />
        <label for="upload" class="btn-upload">Chọn ảnh mới</label>
    </div>

    @Html.ValidationMessage("Image", new { @class = "validation-msg" })

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Cập nhật sản phẩm</button>
        <a href="@Url.Action("Index", "Product")" class="btn btn-ghost">Hủy</a>
    </div>

</div>
}

<script>
    function previewImage(input) {
        var placeholder = document.getElementById('imgPlaceholder');
        var preview = document.getElementById('imgPreview');
        var imgName = document.getElementById('imgName');

        if (input.files && input.files[0]) {
            var file = input.files[0];
            var reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = 'block';
                placeholder.style.display = 'none';
                imgName.textContent = file.name;
            };
            reader.readAsDataURL(file);
        }
    }</script>

