@{
    ViewBag.Title = "Thống kê doanh thu";
    Layout = "~/Areas/Admin/Views/Shared/_layoutAdmin.cshtml";

    int selectedYear = ViewBag.SelectedYear;
    int? selectedMonth = ViewBag.SelectedMonth;
    var allYears = ViewBag.AllYears as List<int> ?? new List<int>();
    decimal[] productRevenue = ViewBag.ProductRevenue as decimal[] ?? new decimal[12];
    decimal[] bookingRevenue = ViewBag.BookingRevenue as decimal[] ?? new decimal[12];
    decimal totalProduct = ViewBag.TotalProductRevenue;
    decimal totalBooking = ViewBag.TotalBookingRevenue;
    decimal grandTotal = ViewBag.GrandTotal;

    var topProducts = ViewBag.TopProducts as List<Thue_san_the_thao.Areas.Admin.Data.TopProductVM>
                      ?? new List<Thue_san_the_thao.Areas.Admin.Data.TopProductVM>();
    var topFields = ViewBag.TopFields as List<Thue_san_the_thao.Areas.Admin.Data.TopFieldVM>
            ?? new List<Thue_san_the_thao.Areas.Admin.Data.TopFieldVM>();

    string[] monthLabels = { "T1", "T2", "T3", "T4", "T5", "T6", "T7", "T8", "T9", "T10", "T11", "T12" };
}

<div class="container-fluid py-4">

    <!-- ===== TIÊU ĐỀ & BỘ LỌC ===== -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-dark mb-0">
            <i class="fas fa-chart-line text-primary me-2"></i>Thống kê doanh thu
        </h4>

        <form method="get" class="d-flex gap-2 align-items-center">
            <select name="year" class="form-select form-select-sm" style="width:110px">
                @foreach (var y in allYears)
                {
                    <option value="@y" @(y == selectedYear ? "selected" : "")>Năm @y</option>
                }
            </select>

            <select name="month" class="form-select form-select-sm" style="width:130px">
                <option value="">-- Cả năm --</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m" @(selectedMonth == m ? "selected" : "")>Tháng @m</option>
                }
            </select>

            <button type="submit" class="btn btn-primary btn-sm px-3">
                <i class="fas fa-search me-1"></i>Lọc
            </button>
        </form>
    </div>

    <!-- ===== THẺ TỔNG QUAN ===== -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0d6efd !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:52px;height:52px;background:#e8f0fe;">
                        <i class="fas fa-money-bill-wave text-primary fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Tổng doanh thu</div>
                        <div class="fw-bold fs-5 text-primary">@grandTotal.ToString("N0") ₫</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #198754 !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:52px;height:52px;background:#e6f4ea;">
                        <i class="fas fa-shopping-bag text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Doanh thu sản phẩm</div>
                        <div class="fw-bold fs-5 text-success">@totalProduct.ToString("N0") ₫</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #fd7e14 !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:52px;height:52px;background:#fff3e0;">
                        <i class="fas fa-futbol text-warning fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Doanh thu đặt sân</div>
                        <div class="fw-bold fs-5 text-warning">@totalBooking.ToString("N0") ₫</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== BIỂU ĐỒ ===== -->
    <div class="row g-3 mb-4">
        <!-- Biểu đồ cột doanh thu theo tháng -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pb-0">
                    <h6 class="fw-semibold text-dark mb-0">
                        <i class="fas fa-bar-chart text-primary me-2"></i>
                        Doanh thu theo tháng — Năm @selectedYear
                    </h6>
                </div>
                <div class="card-body">
                    <canvas id="revenueBarChart" height="100"></canvas>
                </div>
            </div>
        </div>

        <!-- Biểu đồ tròn tỉ lệ -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pb-0">
                    <h6 class="fw-semibold text-dark mb-0">
                        <i class="fas fa-chart-pie text-success me-2"></i>
                        Cơ cấu doanh thu
                    </h6>
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <canvas id="revenuePieChart" height="180"></canvas>
                    <div class="mt-3 text-center small">
                        <span class="badge me-2" style="background:#0d6efd">■</span>Sản phẩm:
                        <strong>@(grandTotal > 0 ? ((totalProduct / grandTotal) * 100).ToString("F1") : "0")%</strong>
                        &nbsp;
                        <span class="badge me-2" style="background:#fd7e14">■</span>Đặt sân:
                        <strong>@(grandTotal > 0 ? ((totalBooking / grandTotal) * 100).ToString("F1") : "0")%</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== BẢNG TOP SẢN PHẨM & TOP SÂN ===== -->
    <div class="row g-3">
        <!-- Top sản phẩm bán chạy -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <h6 class="fw-semibold text-dark mb-0">
                        <i class="fas fa-trophy text-warning me-2"></i>Top 5 sản phẩm bán chạy
                    </h6>
                </div>
                <div class="card-body p-0">
                    @if (topProducts.Count == 0)
                    {
                        <div class="text-center text-muted py-4">Không có dữ liệu</div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">SL</th>
                                    <th class="text-end">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < topProducts.Count; i++)
                                {
                                    var p = topProducts[i];
                                    <tr>
                                        <td>
                                            @if (i == 0)
                                            {<span class="badge bg-warning text-dark">1</span> }
                                            else if (i == 1)
                                            { <span class="badge bg-secondary">2</span> }
                                            else if (i == 2)
                                            { <span class="badge" style="background:#cd7f32">3</span> }
                                            else
                                            { <span class="text-muted">@(i + 1)</span>}
                                        </td>
                                        <td>@p.ProductName</td>
                                        <td class="text-center">@p.TotalQuantity</td>
                                        <td class="text-end fw-semibold text-success">@p.TotalRevenue.ToString("N0") ₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <!-- Top sân được đặt nhiều nhất -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <h6 class="fw-semibold text-dark mb-0">
                        <i class="fas fa-flag-checkered text-primary me-2"></i>Top 5 sân được đặt nhiều nhất
                    </h6>
                </div>
                <div class="card-body p-0">
                    @if (topFields.Count == 0)
                    {
                        <div class="text-center text-muted py-4">Không có dữ liệu</div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Tên sân</th>
                                    <th class="text-center">Lượt đặt</th>
                                    <th class="text-end">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < topFields.Count; i++)
                                {
                                    var f = topFields[i];
                                    <tr>
                                        <td>
                                            @if (i == 0)
                                            {<span class="badge bg-warning text-dark">1</span> }
                                            else if (i == 1)
                                            { <span class="badge bg-secondary">2</span> }
                                            else if (i == 2)
                                            { <span class="badge" style="background:#cd7f32">3</span> }
                                            else
                                            { <span class="text-muted">@(i + 1)</span>}
                                        </td>
                                        <td>@f.FieldName</td>
                                        <td class="text-center">@f.TotalBookings</td>
                                        <td class="text-end fw-semibold text-primary">@f.TotalRevenue.ToString("N0") ₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // ===== Dữ liệu từ server =====
        const productData = [@string.Join(",", productRevenue.Select(v => v.ToString(System.Globalization.CultureInfo.InvariantCulture)))];
        const bookingData = [@string.Join(",", bookingRevenue.Select(v => v.ToString(System.Globalization.CultureInfo.InvariantCulture)))];
        const labels = ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'];

        // ===== Biểu đồ cột =====
        new Chart(document.getElementById('revenueBarChart'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Sản phẩm',
                        data: productData,
                        backgroundColor: 'rgba(13,110,253,0.75)',
                        borderRadius: 5
                    },
                    {
                        label: 'Đặt sân',
                        data: bookingData,
                        backgroundColor: 'rgba(253,126,20,0.75)',
                        borderRadius: 5
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.dataset.label + ': ' + ctx.parsed.y.toLocaleString('vi-VN') + ' ₫'
                        }
                    }
                },
                scales: {
                    y: {
                        ticks: {
                            callback: val => val.toLocaleString('vi-VN') + ' ₫'
                        },
                        beginAtZero: true
                    }
                }
            }
        });

        // ===== Biểu đồ tròn =====
        const totalProduct = @totalProduct.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const totalBooking = @totalBooking.ToString(System.Globalization.CultureInfo.InvariantCulture);

        new Chart(document.getElementById('revenuePieChart'), {
            type: 'doughnut',
            data: {
                labels: ['Sản phẩm', 'Đặt sân'],
                datasets: [{
                    data: [totalProduct, totalBooking],
                    backgroundColor: ['#0d6efd', '#fd7e14'],
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.label + ': ' + ctx.parsed.toLocaleString('vi-VN') + ' ₫'
                        }
                    }
                }
            }
        });
    </script>
}
